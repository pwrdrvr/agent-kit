{
  "name": "@pwrdrvr/agent-chat-react",
  "version": "0.1.1",
  "description": "Presentational React chat UI for agent-kit: renders agent-core neutral thread shapes and emits user intents. Props in, callbacks out — no IPC, bus, or transport.",
  "license": "MIT",
  "author": "PwrDrvr LLC",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --sourcemap && node ./build-css.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@pwrdrvr/agent-core": "workspace:^"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^25.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pwrdrvr/agent-kit.git",
    "directory": "packages/agent-chat-react"
  },
  "keywords": [
    "agent",
    "chat",
    "react",
    "ui",
    "presentational",
    "codex",
    "acp"
  ],
  "publishConfig": {
    "access": "public"
  }
}
