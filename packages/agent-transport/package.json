{
  "name": "@pwrdrvr/agent-transport",
  "version": "0.1.4",
  "description": "Generic JSON-RPC 2.0 core + line-delimited stdio transport for driving local agents (Codex App Server, ACP).",
  "license": "MIT",
  "author": "PwrDrvr LLC",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --sourcemap",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@pwrdrvr/agent-core": "workspace:^"
  },
  "devDependencies": {
    "@types/node": "^24.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pwrdrvr/agent-kit.git",
    "directory": "packages/agent-transport"
  },
  "keywords": [
    "json-rpc",
    "stdio",
    "agent",
    "codex",
    "acp",
    "transport"
  ],
  "publishConfig": {
    "access": "public"
  }
}
