{
  "name": "@pwrdrvr/codex-discovery",
  "version": "0.1.0",
  "description": "Discover local Codex CLI binaries (version-ranked), enumerate auth profiles, and drive login / relogin — Electron-free, host-injected logger + openExternal.",
  "license": "MIT",
  "author": "PwrDrvr LLC",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --sourcemap",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@pwrdrvr/agent-core": "workspace:^"
  },
  "devDependencies": {
    "@types/node": "^24.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pwrdrvr/agent-kit.git",
    "directory": "packages/codex-discovery"
  },
  "keywords": [
    "codex",
    "discovery",
    "agent",
    "oauth",
    "login"
  ],
  "publishConfig": {
    "access": "public"
  }
}
